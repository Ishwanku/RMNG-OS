# RMNG MCP production allowlist — rmngd proxy plane only
# =============================================================================
# Copy to: ~/.rmng/mcp-allowlist.toml
# Seed:    ./scripts/setup-mcp-allowlist.sh
# Add:     ./scripts/register-mcp-tool.sh <server> <cmd> [args] --tools t1,t2
#
# ADR-014: Only explicitly listed servers/tools may execute via mcp.proxy intents.
# ADR-010: This is the BODY path — not IDE dev MCP (~/.config/rmng/mcp-dev.json).
#
# Schema (matches agents/rmng-core/src/allowlist.rs):
#   [servers.<name>]
#   enabled         = true | false
#   command         = "npx" | "uvx" | absolute path
#   args            = ["arg1", "arg2"]
#   allowed_tools   = ["tool.id", "another.tool"]   # NO wildcards
#
# Intent wire format (ADR-015):
#   { "kind": "mcp.proxy", "server": "<name>", "tool": "<tool.id>", "params": {} }
#
# Tool naming: allowlist uses dotted IDs (git.log); rmng-mcp maps to MCP wire names.
# After edits: systemctl --user restart rmngd
# Audit:       tail ~/.rmng/logs/audit.jsonl
# Docs:        docs/INTEGRATION-STRATEGY.md · docs/integrations/
# =============================================================================

[servers.github]
enabled = true
command = "npx"
args = ["-y", "@github/github-mcp-server"]
# Read-only issue intelligence (no create_issue — write ops denied)
allowed_tools = ["search_issues", "list_issues", "get_issue"]

[servers.git]
enabled = true
command = "uvx"
args = ["mcp-server-git", "--repository", "/path/to/RMNG-OS"]
allowed_tools = ["git.log", "git.diff", "git.status"]

# Sprint 12–13 — read-only URL fetch (Track 2)
[servers.fetch]
enabled = true
command = "npx"
args = ["-y", "@modelcontextprotocol/server-fetch"]
allowed_tools = ["fetch"]

[servers.fetch.isolation]
memory_mb = 256
pids_max = 32
cgroup = true
new_session = true
# seccomp_profile = "basic"  # optional; off by default for compatibility

# Sprint 13 — document → markdown (Track 2; https/file/data URIs only)
[servers.markitdown]
enabled = true
command = "uvx"
args = ["markitdown-mcp"]
allowed_tools = ["convert_to_markdown"]

[servers.markitdown.isolation]
memory_mb = 512
pids_max = 48
cgroup = true
new_session = true
no_new_privs = true

# Sprint 14 — DOM navigation (opt-in: disabled by default; enable explicitly)
[servers.playwright]
enabled = false
command = "npx"
args = ["-y", "@playwright/mcp@latest"]
allowed_tools = ["browser_navigate", "browser_snapshot", "browser_click"]

[servers.playwright.isolation]
memory_mb = 1024
pids_max = 128
cgroup = true
new_session = true
no_new_privs = true
seccomp_profile = "playwright"
drop_capabilities = true

# Per-server isolation override (optional — merges over global [isolation] in config.toml)
# [servers.git.isolation]
# memory_mb = 256
# cgroup = true

# Sprint 15 — long-term memory (opt-in; requires MEM0_API_KEY in rmngd env)
[servers.mem0]
enabled = false
command = "uvx"
args = ["mem0-mcp-server"]
allowed_tools = ["add_memory", "search_memories", "get_memory", "delete_memory"]

[servers.mem0.isolation]
memory_mb = 512
pids_max = 64
cgroup = true
new_session = true
no_new_privs = true

# Sprint 17 — sandboxed code execution (opt-in; requires E2B_API_KEY in rmngd env)
[servers.e2b]
enabled = false
command = "npx"
args = ["-y", "@e2b/mcp-server"]
allowed_tools = ["run_code"]

[servers.e2b.isolation]
memory_mb = 512
pids_max = 64
cgroup = true
new_session = true
no_new_privs = true
seccomp_profile = "e2b"
drop_capabilities = true
