# RMNG-OS BYO-LLM configuration
# Install: cp config/rmng-config.toml.example ~/.rmng/config.toml
# Model catalog (edit without rebuild): config/llm-catalog.toml
# Docs: docs/llm-configuration.md

# Optional: active profile name (must be at root — not under [llm])
# profile = "gemini-fast"

[llm]
llm_provider = "none"

# Model id (see: rmng llm models --provider <id>)
# model = "gemini-3.5-flash"

# API key via environment (recommended)
# api_key_env_var = "GOOGLE_API_KEY"

# endpoint_url = "http://127.0.0.1:11434"
# max_retries = 2
# timeout_secs = 120

# Named profiles — switch with: rmng llm use <name>

[[profiles]]
name = "gemini-fast"
llm_provider = "google"
model = "gemini-3.5-flash"
api_key_env_var = "GOOGLE_API_KEY"

[[profiles]]
name = "gemini-reasoning"
llm_provider = "google"
model = "gemini-3.1-pro-preview"
api_key_env_var = "GOOGLE_API_KEY"

[[profiles]]
name = "grok-frontier"
llm_provider = "grok"
model = "grok-4.3"
api_key_env_var = "XAI_API_KEY"

[[profiles]]
name = "anthropic-economy"
llm_provider = "anthropic"
model = "claude-3-5-haiku-20241022"
api_key_env_var = "ANTHROPIC_API_KEY"
max_retries = 1

[[profiles]]
name = "local-ollama"
llm_provider = "ollama"
endpoint_url = "http://127.0.0.1:11434"
model = "llama3.2"

[[profiles]]
name = "groq-fast"
llm_provider = "groq"
model = "llama-3.3-70b-versatile"
api_key_env_var = "GROQ_API_KEY"